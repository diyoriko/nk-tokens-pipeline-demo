{
  "motion": {
    "duration": {
      "fast":   { "$type": "duration", "$value": "100ms" },
      "base":   { "$type": "duration", "$value": "200ms" },
      "slow":   { "$type": "duration", "$value": "300ms" },
      "slower": { "$type": "duration", "$value": "500ms" }
    },
    "easing": {
      "standard":   { "$type": "cubicBezier", "$value": "cubic-bezier(0.2, 0, 0, 1)" },
      "decelerate": { "$type": "cubicBezier", "$value": "cubic-bezier(0, 0, 0, 1)" },
      "accelerate": { "$type": "cubicBezier", "$value": "cubic-bezier(0.3, 0, 1, 1)" }
    }
  },
  "z-index": {
    "base":     { "$type": "number", "$value": 0 },
    "dropdown": { "$type": "number", "$value": 1000 },
    "sticky":   { "$type": "number", "$value": 1100 },
    "overlay":  { "$type": "number", "$value": 1200 },
    "modal":    { "$type": "number", "$value": 1300 },
    "toast":    { "$type": "number", "$value": 1400 }
  },
  "opacity": {
    "disabled": { "$type": "number", "$value": 0.4 },
    "muted":    { "$type": "number", "$value": 0.6 }
  }
}
