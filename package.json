{
  "name": "@diyoriko/nk-tokens",
  "version": "0.1.0",
  "type": "module",
  "description": "Novakid design tokens — generated --nk-* CSS / Dart / TS from the Figma -> Tokens Studio -> Style Dictionary pipeline.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diyoriko/nk-tokens-pipeline-demo.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "build"
  ],
  "exports": {
    "./css/variables.css": "./build/css/variables.css",
    "./tokens": "./build/ts/tokens.ts",
    "./dart/nk_colors.dart": "./build/dart/nk_colors.dart"
  },
  "scripts": {
    "build:tokens": "node build-tokens.mjs",
    "storybook": "npm run build:tokens && storybook dev -p 6006",
    "build-storybook": "npm run build:tokens && storybook build",
    "prepack": "npm run build:tokens"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/html-vite": "^8.6.0",
    "storybook": "^8.6.0",
    "style-dictionary": "^4.3.3",
    "vite": "^5.4.0"
  }
}
